{
  "info": {
    "name": "Ohrny — Chat Module",
    "description": "Complete test collection for the Ohrny chat backend: matches, messages, photo unlock, calls, and unmatch.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "tokenA", "value": "PASTE_USER_A_ACCESS_TOKEN_HERE" },
    { "key": "tokenB", "value": "PASTE_USER_B_ACCESS_TOKEN_HERE" },
    { "key": "matchId", "value": "PASTE_MATCH_UUID_HERE" },
    { "key": "callId", "value": "PASTE_CALL_UUID_HERE" }
  ],
  "item": [
    {
      "name": "Auth (helpers)",
      "item": [
        {
          "name": "Send OTP — User A",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/user/auth/send-otp", "host": ["{{baseUrl}}"], "path": ["user", "auth", "send-otp"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"5551234567\",\n  \"phoneCountry\": \"+1\"\n}"
            }
          }
        },
        {
          "name": "Verify OTP — User A",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken) {",
                  "  pm.collectionVariables.set('tokenA', res.accessToken);",
                  "  console.log('tokenA saved');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/user/auth/verify-otp", "host": ["{{baseUrl}}"], "path": ["user", "auth", "verify-otp"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"5551234567\",\n  \"phoneCountry\": \"+1\",\n  \"code\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Send OTP — User B",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/user/auth/send-otp", "host": ["{{baseUrl}}"], "path": ["user", "auth", "send-otp"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"5559876543\",\n  \"phoneCountry\": \"+1\"\n}"
            }
          }
        },
        {
          "name": "Verify OTP — User B",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken) {",
                  "  pm.collectionVariables.set('tokenB', res.accessToken);",
                  "  console.log('tokenB saved');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/user/auth/verify-otp", "host": ["{{baseUrl}}"], "path": ["user", "auth", "verify-otp"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"5559876543\",\n  \"phoneCountry\": \"+1\",\n  \"code\": \"123456\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Matches",
      "item": [
        {
          "name": "List my matches (User A)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.matches && res.matches.length > 0) {",
                  "  pm.collectionVariables.set('matchId', res.matches[0].matchId);",
                  "  console.log('matchId saved:', res.matches[0].matchId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenA}}" }],
            "url": { "raw": "{{baseUrl}}/user/matches", "host": ["{{baseUrl}}"], "path": ["user", "matches"] }
          }
        },
        {
          "name": "List my matches (User B)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenB}}" }],
            "url": { "raw": "{{baseUrl}}/user/matches", "host": ["{{baseUrl}}"], "path": ["user", "matches"] }
          }
        }
      ]
    },
    {
      "name": "Messages",
      "item": [
        {
          "name": "Send message (User A)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenA}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/user/matches/{{matchId}}/messages", "host": ["{{baseUrl}}"], "path": ["user", "matches", "{{matchId}}", "messages"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Hey! How are you?\"\n}"
            }
          }
        },
        {
          "name": "Send message (User B)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenB}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/user/matches/{{matchId}}/messages", "host": ["{{baseUrl}}"], "path": ["user", "matches", "{{matchId}}", "messages"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"I'm good! Nice to match with you.\"\n}"
            }
          }
        },
        {
          "name": "Get messages (User A)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenA}}" }],
            "url": {
              "raw": "{{baseUrl}}/user/matches/{{matchId}}/messages?limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["user", "matches", "{{matchId}}", "messages"],
              "query": [{ "key": "limit", "value": "20" }]
            }
          }
        },
        {
          "name": "Get messages with cursor (User A)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenA}}" }],
            "url": {
              "raw": "{{baseUrl}}/user/matches/{{matchId}}/messages?limit=10&cursor=PASTE_CURSOR_HERE",
              "host": ["{{baseUrl}}"],
              "path": ["user", "matches", "{{matchId}}", "messages"],
              "query": [
                { "key": "limit", "value": "10" },
                { "key": "cursor", "value": "PASTE_CURSOR_HERE", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Mark messages as read (User A)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenA}}" }],
            "url": { "raw": "{{baseUrl}}/user/matches/{{matchId}}/read", "host": ["{{baseUrl}}"], "path": ["user", "matches", "{{matchId}}", "read"] }
          }
        },
        {
          "name": "Mark messages as read (User B)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenB}}" }],
            "url": { "raw": "{{baseUrl}}/user/matches/{{matchId}}/read", "host": ["{{baseUrl}}"], "path": ["user", "matches", "{{matchId}}", "read"] }
          }
        }
      ]
    },
    {
      "name": "Photo Unlock",
      "item": [
        {
          "name": "Request unlock (User A)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenA}}" }],
            "url": { "raw": "{{baseUrl}}/user/matches/{{matchId}}/unlock", "host": ["{{baseUrl}}"], "path": ["user", "matches", "{{matchId}}", "unlock"] }
          }
        },
        {
          "name": "Accept unlock (User B) — completes mutual unlock",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenB}}" }],
            "url": { "raw": "{{baseUrl}}/user/matches/{{matchId}}/unlock", "host": ["{{baseUrl}}"], "path": ["user", "matches", "{{matchId}}", "unlock"] }
          }
        }
      ]
    },
    {
      "name": "Calls",
      "item": [
        {
          "name": "Initiate voice call (User A)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.call && res.call.id) {",
                  "  pm.collectionVariables.set('callId', res.call.id);",
                  "  console.log('callId saved:', res.call.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenA}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/user/matches/{{matchId}}/calls", "host": ["{{baseUrl}}"], "path": ["user", "matches", "{{matchId}}", "calls"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"voice\"\n}"
            }
          }
        },
        {
          "name": "Initiate video call (User A)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.call && res.call.id) {",
                  "  pm.collectionVariables.set('callId', res.call.id);",
                  "  console.log('callId saved:', res.call.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenA}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/user/matches/{{matchId}}/calls", "host": ["{{baseUrl}}"], "path": ["user", "matches", "{{matchId}}", "calls"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"video\"\n}"
            }
          }
        },
        {
          "name": "Answer call (User B)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenB}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/user/calls/{{callId}}", "host": ["{{baseUrl}}"], "path": ["user", "calls", "{{callId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"answered\"\n}"
            }
          }
        },
        {
          "name": "End call (User A)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenA}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/user/calls/{{callId}}", "host": ["{{baseUrl}}"], "path": ["user", "calls", "{{callId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"ended\"\n}"
            }
          }
        },
        {
          "name": "Decline call (User B)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{tokenB}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/user/calls/{{callId}}", "host": ["{{baseUrl}}"], "path": ["user", "calls", "{{callId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"declined\"\n}"
            }
          }
        },
        {
          "name": "Get call history",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenA}}" }],
            "url": { "raw": "{{baseUrl}}/user/matches/{{matchId}}/calls", "host": ["{{baseUrl}}"], "path": ["user", "matches", "{{matchId}}", "calls"] }
          }
        }
      ]
    },
    {
      "name": "Unmatch",
      "item": [
        {
          "name": "Unmatch (User A)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenA}}" }],
            "url": { "raw": "{{baseUrl}}/user/matches/{{matchId}}", "host": ["{{baseUrl}}"], "path": ["user", "matches", "{{matchId}}"] }
          }
        }
      ]
    }
  ]
}
